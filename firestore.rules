rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isTenant(tenantId) {
      return isAuth() && request.auth.uid == tenantId;
    }

    // Users
    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // Products — her tenant kendi ürünlerine erişir
    match /products/{productId} {
      allow read: if isAuth() && resource.data.tenantId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.tenantId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.tenantId == request.auth.uid;
    }

    // Stock movements
    match /stockMovements/{movId} {
      allow read: if isAuth() && resource.data.tenantId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.tenantId == request.auth.uid;
    }

    // Sales
    match /sales/{saleId} {
      allow read: if isAuth() && resource.data.tenantId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isAuth() && resource.data.tenantId == request.auth.uid;
    }

    // Customers
    match /customers/{customerId} {
      allow read: if isAuth() && resource.data.tenantId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.tenantId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.tenantId == request.auth.uid;
    }

    // Credits
    match /credits/{creditId} {
      allow read: if isAuth() && resource.data.tenantId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isAuth() && resource.data.tenantId == request.auth.uid;
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read: if isAuth() && resource.data.tenantId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.tenantId == request.auth.uid;
      allow delete: if isAuth() && resource.data.tenantId == request.auth.uid;
    }

    // Credit Transactions
    match /creditTransactions/{txId} {
      allow read: if isAuth() && resource.data.tenantId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isAuth() && resource.data.tenantId == request.auth.uid;
    }
  }
}
