{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tarım Market Pro",
  "version": "1.0.0",
  "identifier": "com.tarimmarket.pro",
  "build": {
    "frontendDist": "../dist/tarim-market/browser",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tarım Market Pro",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": {
          "tr-TR": {
            "localePath": "wix/tr-TR.wxl"
          }
        }
      }
    }
  }
}
